APP_NAME=ARGUS API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./argus.db
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DEFAULT_MUNICIPIO=Macae
TCE_BASE_URL=https://dados.tcerj.tc.br/api/v1

# Quando true, limpa TODOS os registros antes de rodar o sync (reset completo).
# Use apenas após alterações em filtros/scoring. Volte para false depois.
FORCE_RESET=true
