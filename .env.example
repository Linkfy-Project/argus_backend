APP_NAME=ARGUS API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./argus.db
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DEFAULT_MUNICIPIO=Macae
TCE_BASE_URL=https://dados.tcerj.tc.br/api/v1

# Quando true, limpa TODOS os registros antes de rodar o sync (reset completo).
# Use apenas após alterações em filtros/scoring. Volte para false depois.
FORCE_RESET=true

# ── Google Maps Geocoding API ──
# Chave de API do Google Maps (obtenha em https://console.cloud.google.com/)
# Habilite a Geocoding API e crie uma API Key com restrição de API
GOOGLE_MAPS_API_KEY=sua-chave-aqui
# Limite de endereços para geocodificar (0 = sem limite, processa todos)
# Mude para 0 depois de validar que está tudo OK
GEOCODE_LIMIT=10
# Quando true, endereços não encontrados pela API recebem coordenadas aleatórias
# Quando false, apenas endereços encontrados pela API recebem coordenadas
GEOCODE_FALLBACK_RANDOM=false

# ── OpenRouter (Pipeline de IA) ──
# Chave de API do OpenRouter (obtenha em https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui
# ID do modelo a ser usado (ex: meta-llama/llama-3.1-8b-instruct, qwen/qwen3-32b)
OPENROUTER_MODEL_ID=meta-llama/llama-3.1-8b-instruct
# Provedor preferido no OpenRouter (ex: Groq, Together, DeepInfra)
OPENROUTER_PROVIDER=Groq
# Número máximo de workers paralelos (padrão: 4)
AI_PIPELINE_MAX_WORKERS=4
# Timeout em segundos por chamada (padrão: 60)
AI_PIPELINE_TIMEOUT=60
# Limite de descrições para processar (0 = sem limite, processa todas)
# Mude para 0 depois de validar que está tudo OK
AI_PIPELINE_LIMIT=10
